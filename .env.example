# Environment Configuration
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# GLM-4 Configuration
GLM__API_KEY=your-glm-api-key-here
GLM__BASE_URL=https://open.bigmodel.cn/api/paas/v4

# DeepSeek Configuration
DEEPSEEK__API_KEY=your-deepseek-api-key-here
DEEPSEEK__BASE_URL=https://api.deepseek.com

# Claude Configuration
CLAUDE__API_KEY=your-claude-api-key-here
CLAUDE__BASE_URL=https://api.anthropic.com

# OpenAI Configuration
OPENAI__API_KEY=your-openai-api-key-here
OPENAI__BASE_URL=https://api.openai.com/v1

# DeepInfra Configuration
DEEPINFRA__API_KEY=your-deepinfra-api-key-here
DEEPINFRA__BASE_URL=https://api.deepinfra.com/v1/openai

# Database Configuration
DATABASE__URL=postgresql://user:password@localhost/luciddreamer_router
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=20

# Redis Configuration
REDIS__URL=redis://localhost:6379/0
REDIS__MAX_CONNECTIONS=10

# Budget Configuration
BUDGET__DAILY_BUDGET_USD=100.0
BUDGET__WARNING_THRESHOLD_PERCENTAGE=80.0
BUDGET__HARD_LIMIT_PERCENTAGE=95.0

# Routing Configuration
ROUTING__GLM_PRIMARY_WEIGHT=0.95
ROUTING__COST_SENSITIVITY_FACTOR=0.7
ROUTING__QUALITY_WEIGHT=0.3
ROUTING__FALLBACK_ENABLED=true

# Monitoring Configuration
MONITORING__LOG_LEVEL=INFO
MONITORING__ENABLE_TRACING=true
MONITORING__PERFORMANCE_TRACKING_ENABLED=true

# Queue Configuration
MAX_QUEUE_SIZE=1000
QUEUE_TIMEOUT_SECONDS=300